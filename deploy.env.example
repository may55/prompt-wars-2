# ==========================================
# VM SSH Connection Details
# ==========================================
VM_HOST=your-vm-public-ip-or-domain
VM_USER=ubuntu
VM_KEY_PATH=~/.ssh/your-ssh-key.pem
VM_TARGET_DIR=/var/www/prompt-wars-2

# ==========================================
# Application Ports
# ==========================================
BACKEND_PORT=3000
FRONTEND_PORT=3001

# ==========================================
# Azure OpenAI Credentials (for Backend)
# ==========================================
# These will be dynamically written to the VM's backend .env file on deploy
AOAI_ENDPOINT=https://your-resource-name.openai.azure.com/
API_KEY=your-azure-openai-api-key
DEPLOYMENT_NAME=gpt-4o-mini
API_VERSION=2024-04-01-preview
